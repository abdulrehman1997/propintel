# Next.js + updater shared env vars
# Copy to .env.local for Next.js development

# Postgres connection (Next-side read pool)
DATABASE_URL=postgres://propintel:propintel@localhost:5432/propintel

# US Census Bureau API key — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# HUD User API token — https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=

# FRED (Federal Reserve Economic Data) API key — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BLS (Bureau of Labor Statistics) API key — https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Comma-separated zip codes to seed on first run (used by updater)
SEED_ZIPS=17101,17102,19103,15213

# node-cron schedule for updater (default: 3 AM daily)
CRON_SCHEDULE=0 3 * * *

# Local LLM for natural-language search (optional; page degrades gracefully if absent)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
