<script>
// ── Page navigation (sidebar + buttons) ──
function showPage(page) {
  document.querySelectorAll('.section').forEach(function(s) { s.classList.remove('active'); });
  var target = document.getElementById('page-' + page);
  if (target) target.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(function(n) { n.classList.remove('active'); });
  var navItem = document.querySelector('.nav-item[data-page="'+page+'"]');
  if (navItem) navItem.classList.add('active');
  var titles = { dashboard:'Dashboard', search:'Property Search', deals:'Deal Analyzer', markets:'Market Intelligence', scoring:'Scoring Engine', portfolio:'My Portfolio', alerts:'Alerts & Saved Searches' };
  document.getElementById('pageTitle').textContent = titles[page] || page;
}

// ── Tab switching (delegates to closest .tab, handles child clicks) ──
document.addEventListener('click', function(e) {
  var tab = e.target.closest('.tab');
  if (!tab) return;
  var container = tab.parentElement;
  container.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
  tab.classList.add('active');
});

// ── Filter chips (exclusive "All Types" vs multi-select others) ──
document.getElementById('filterBar').addEventListener('click', function(e) {
  var chip = e.target.closest('.filter-chip');
  if (!chip) return;
  var allChip = this.querySelector('[data-filter="all"]');
  if (chip.dataset.filter === 'all') {
    this.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
    allChip.classList.add('active');
  } else {
    allChip.classList.remove('active');
    chip.classList.toggle('active');
    var anyActive = this.querySelectorAll('.filter-chip.active:not([data-filter="all"])').length > 0;
    if (!anyActive) allChip.classList.add('active');
  }
});

// ── Deal Analyzer live recalculation ──
function parseCurrency(str) {
  return parseFloat(String(str).replace(/[^0-9.\-]/g, '')) || 0;
}
function formatCurrency(n) {
  return '$' + Math.round(n).toLocaleString();
}
function recalcDeal() {
  var price       = parseCurrency(document.getElementById('purchasePrice').value);
  var downPct     = parseFloat(document.getElementById('downPct').value) || 0;
  var rate        = parseFloat(document.getElementById('intRate').value) || 0;
  var termYears   = parseFloat(document.getElementById('loanTerm').value) || 30;
  var closing     = parseCurrency(document.getElementById('closingCost').value);
  var rehab       = parseCurrency(document.getElementById('rehabCost').value);
  var rent        = parseCurrency(document.getElementById('monthlyRent').value);

  var downPayment = price * downPct / 100;
  var loanAmount  = price - downPayment;
  var totalCash   = downPayment + closing + rehab;

  // Monthly P&I (standard amortization)
  var monthlyRate = rate / 100 / 12;
  var numPayments = termYears * 12;
  var monthlyPI   = 0;
  if (monthlyRate > 0 && numPayments > 0) {
    monthlyPI = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) / (Math.pow(1 + monthlyRate, numPayments) - 1);
  } else if (numPayments > 0) {
    monthlyPI = loanAmount / numPayments;
  }

  // Expenses
  var taxYr       = parseCurrency(document.querySelectorAll('#page-deals .input-group input')[5].value);
  var insYr       = parseCurrency(document.querySelectorAll('#page-deals .input-group input')[6].value);
  var vacPct      = parseFloat(document.querySelectorAll('#page-deals .input-group input')[7].value) || 0;
  var mgmtPct     = parseFloat(document.querySelectorAll('#page-deals .input-group input')[8].value) || 0;
  var maintMo     = parseCurrency(document.querySelectorAll('#page-deals .input-group input')[9].value);

  var vacancyLoss = rent * vacPct / 100;
  var mgmtFee     = rent * mgmtPct / 100;
  var totalExpMo  = monthlyPI + (taxYr / 12) + (insYr / 12) + vacancyLoss + mgmtFee + maintMo;
  var cashFlow    = rent - totalExpMo;

  // Ratios
  var noi         = (rent * 12) - (taxYr + insYr + (vacancyLoss*12) + (mgmtFee*12) + (maintMo*12));
  var capRate     = price > 0 ? (noi / price * 100) : 0;
  var coc         = totalCash > 0 ? (cashFlow * 12 / totalCash * 100) : 0;
  var dscr        = monthlyPI > 0 ? ((rent - vacancyLoss) / monthlyPI) : 0;

  // Update result rows
  var rows = document.querySelectorAll('#page-deals .result-row .result-value');
  if (rows.length >= 11) {
    rows[0].textContent = formatCurrency(downPayment);
    rows[1].textContent = formatCurrency(totalCash);
    rows[2].textContent = formatCurrency(loanAmount);
    rows[3].textContent = formatCurrency(monthlyPI);
    rows[4].textContent = formatCurrency(totalExpMo);
    // Cash flow (special highlighted row)
    var cfEl2 = document.getElementById('cashFlowResult');
    cfEl2.textContent = formatCurrency(cashFlow);
    cfEl2.className = 'result-value ' + (cashFlow >= 0 ? 'positive' : 'negative');
    // Below the highlight
    rows[6].textContent = capRate.toFixed(1) + '%';
    rows[6].className = 'result-value ' + (capRate >= 5 ? 'positive' : 'negative');
    rows[7].textContent = coc.toFixed(1) + '%';
    rows[7].className = 'result-value ' + (coc >= 5 ? 'positive' : 'negative');
    // IRR placeholder
    rows[8].textContent = (coc * 1.45).toFixed(1) + '%';
    rows[8].className = 'result-value positive';
    rows[9].textContent = dscr.toFixed(2) + 'x';
    rows[9].className = 'result-value ' + (dscr >= 1.2 ? 'positive' : 'negative');
  }
}

// ── Weight sliders ──
function updateWeight(n) {
  var v = document.getElementById('w'+n).value;
  document.getElementById('w'+n+'v').textContent = v + '%';
  var wTotal = 0;
  for (var i = 1; i <= 8; i++) wTotal += parseInt(document.getElementById('w'+i).value);
  var el = document.getElementById('totalWeight');
  el.textContent = wTotal + '%';
  el.style.color = wTotal === 100 ? 'var(--green)' : 'var(--red)';
}
function resetWeights() {
  var defaults = [20,15,10,15,10,10,10,10];
  defaults.forEach(function(v,i) {
    document.getElementById('w'+(i+1)).value = v;
    document.getElementById('w'+(i+1)+'v').textContent = v+'%';
  });
  document.getElementById('totalWeight').textContent = '100%';
  document.getElementById('totalWeight').style.color = 'var(--green)';
}

